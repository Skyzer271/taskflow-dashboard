# ─────────────────────────────────────────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────────────────────────────────────────

# API base URL used by the React app.
# Leave empty when the backend serves the frontend on the same origin
# (e.g. Render, Railway, or local production build).
# For separate frontend hosting (GitHub Pages, Vercel, Netlify) set the public
# backend URL, e.g.:
# VITE_API_URL=https://taskflow-api.onrender.com
VITE_API_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Backend
# ─────────────────────────────────────────────────────────────────────────────

# Port the Express server listens on. Render sets this automatically.
PORT=3001

# Set to "production" so the backend serves the static dist/ build.
NODE_ENV=development

# Secret used to sign JWT tokens. Generate a strong random string for production.
JWT_SECRET=change-this-secret-in-production

# CORS origins. Comma-separated list of allowed frontend URLs.
# Leave empty to allow all origins (acceptable while the backend serves the UI).
# Example: ALLOWED_ORIGINS=https://taskflow-dashboard.onrender.com,https://app.example.com
ALLOWED_ORIGINS=

# Path to the SQLite database file.
# For local development this defaults to server/data/taskflow.db.
# For Fly.io or Render with a persistent disk use DB_PATH=/data/taskflow.db.
DB_PATH=

# Default admin account, created automatically by "npm run server:seed".
ADMIN_EMAIL=admin@taskflow.local
ADMIN_PASSWORD=admin123
