# Frontend API URL
# Leave empty for local development (uses Vite proxy to localhost:3001)
# For GitHub Pages or Vercel, set this to your public backend URL, e.g.:
# VITE_API_URL=https://taskflow-api.example.com
VITE_API_URL=

# Backend settings
PORT=3001
JWT_SECRET=change-this-secret-in-production
NODE_ENV=development

# Default admin account (created by npm run server:seed)
ADMIN_EMAIL=admin@taskflow.local
ADMIN_PASSWORD=admin123
